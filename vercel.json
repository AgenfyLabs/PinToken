{
  "outputDirectory": "website",
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "rewrites": [
    { "source": "/zh", "destination": "/zh/index.html" },
    { "source": "/zh/", "destination": "/zh/index.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
